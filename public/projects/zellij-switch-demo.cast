u001b]8;;\u001b\\ \u001b[33m\u001b[1mdtsf\u001b[m\u001b]8;;\u001b\\ \u001b[33m\u001b[1musers\u001b[m\u001b]8;;\u001b\\ \u001b[34m25 dez  2025\u001b[m\u001b]8;;\u001b\\ \u001b[34m\u001b[1mgithub.com\u001b[m\u001b]8;;\u001b\\                                                                                                           \u001b[5;1H\u001b[m\u001b[38;2;120;169;255m\u001b[49m\u001b[59m\u001b[29m\u001b[28m\u001b[27m\u001b[25m\u001b[25m\u001b[1m\u001b[24m\u001b[22m\u001b[1m\u001b[23m\u001b]8;;\u001b\\~\u001b[m\u001b]8;;\u001b\\ \u001b[38;2;120;169;255m💀\u001b[m\u001b]8;;\u001b\\ ll \u001b[38;2;66;190;101m~/src\u001b[m\u001b]8;;\u001b\\                                                                                                                                             \u001b[6;1H\u001b[m\u001b[34m\u001b[49m\u001b[59m\u001b[29m\u001b[28m\u001b[27m\u001b[25m\u001b[25m\u001b[1m\u001b[24m\u001b[22m\u001b[1m\u001b[23m\u001b]8;;\u001b\\d\u001b[33mr\u001b[31mw\u001b[32mx\u001b[33m\u001b[22m\u001b[24mr\u001b[90m\u001b[1m-\u001b[32m\u001b[22m\u001b[24mx\u001b[33mr\u001b[90m\u001b[1m-\u001b[32m\u001b[22m\u001b[24mx\u001b[m\u001b]8;;\u001b\\ \u001b[90m\u001b[1m-\u001b[m\u001b]8;;\u001b\\ \u001b[33m\u001b[1mdtsf\u001b[m\u001b]8;;\u001b\\ \u001b[33m\u001b[1musers\u001b[m\u001b]8;;\u001b\\ \u001b[34m28 dez  2025\u001b[m\u001b]8;;\u001b\\ \u001b[34m\u001b[1maur.archlinux.org\u001b[m\u001b]8;;\u001b\\                                                                                                    \u001b[7;1H\u001b[m\u001b[34m\u001b[49m\u001b[59m\u001b[29m\u001b[28m\u001b[27m\u001b[25m\u001b[25m\u001b[1m\u001b[24m\u001b[22m\u001b[1m\u001b[23m\u001b]8;;\u001b\\d\u001b[33mr\u001b[31mw\u001b[32mx\u001b[33m\u001b[22m\u001b[24mr\u001b[90m\u001b[1m-\u001b[32m\u001b[22m\u001b[24mx\u001b[33mr\u001b[90m\u001b[1m-\u001b[32m\u001b[22m\u001b[24mx\u001b[m\u001b]8;;\u001b\\ \u001b[90m\u001b[1m-\u001b[m\u001b]8;;\u001b\\ \u001b[33m\u001b[1mdtsf\u001b[m\u001b]8;;\u001b\\ \u001b[33m\u001b[1musers\u001b[m\u001b]8;;\u001b\\ \u001b[34m11 jan 03:11\u001b[m\u001b]8;;\u001b\\ \u001b[34m\u001b[1mgithub.com\u001b[m\u001b]8;;\u001b\\                                                                                                           \u001b[8;1H\u001b[m\u001b[38;2;120;169;255m\u001b[49m\u001b[59m\u001b[29m\u001b[28m\u001b[27m\u001b[25m\u001b[25m\u001b[1m\u001b[24m\u001b[22m\u001b[1m\u001b[23m\u001b]8;;\u001b\\~\u001b[m\u001b]8;;\u001b\\ \u001b[38;2;120;169;255m💀\u001b[m\u001b]8;;\u001b\\ # using ghq                                                                                                                                          \u001b[9;1H\u001b[m\u001b[38;2;120;169;255m\u001b[49m\u001b[59m\u001b[29m\u001b[28m\u001b[27m\u001b[25m\u001b[25m\u001b[1m\u001b[24m\u001b[22m\u001b[1m\u001b[23m\u001b]8;;\u001b\\~\u001b[m\u001b]8;;\u001b\\ \u001b[38;2;120;169;255m💀\u001b[m\u001b]8;;\u001b\\ ghq                                                                                                                                                  \u001b[10;1H\u001b[m\u001b[m\u001b]8;;\u001b\\NAME:                                                                                                                                                     \u001b[11;1H\u001b[m\u001b[m\u001b]8;;\u001b\\   ghq - Manage remote repository clones                                                                                                                  \u001b[12;1H\u001b[m\u001b[m\u001b]8;;\u001b\\                                                                                                                                                          \u001b[13;1H\u001b[m\u001b[m\u001b]8;;\u001b\\USAGE:                                                                                                                                                    \u001b[14;1H\u001b[m\u001b[m\u001b]8;;\u001b\\   ghq [global options] command [command options]                                            