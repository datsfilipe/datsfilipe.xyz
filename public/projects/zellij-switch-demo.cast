[36.788682, "o", "                                                                                 \u001b[16;1H\u001b[m\u001b[m\u001b]8;;\u001b\\VERSION:                                                                                                                                                  \u001b[17;1H\u001b[m\u001b[m\u001b]8;;\u001b\\   1.8.1 (rev:HEAD)                                                                                                                                       \u001b[18;1H\u001b[m\u001b[m\u001b]8;;\u001b\\                                                                                                                                                          \u001b[19;1H\u001b[m\u001b[m\u001b]8;;\u001b\\AUTHORS:                                                                                                                                                  \u001b[20;1H\u001b[m\u001b[m\u001b]8;;\u001b\\   motemen <motemen@gmail.com>                                                                                                                            \u001b[21;1H\u001b[m\u001b[m\u001b]8;;\u001b\\   Songmu <y.songmu@gmail.com>                                                                                                                            \u001b[22;1H\u001b[m\u001b[m\u001b]8;;\u001b\\                                                                                                                                                          \u001b[23;1H\u001b[m\u001b[m\u001b]8;;\u001b\\COMMANDS:                                                                                                                                                 \u001b[24;1H\u001b[m\u001b[m\u001b]8;;\u001b\\   get, clone  Clone/sync with a remote repository                                                                                                        \u001b[25;1H\u001b[m\u001b[m\u001b]8;;\u001b\\   list        List local repositories                 